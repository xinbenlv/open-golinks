# 数据库 - Supabase Postgres connection string
# 形如: postgres://postgres.xxx:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# 服务端口 (Railway 自动注入 PORT, 本地开发默认 3000)
PORT=3000

# 运行环境
NODE_ENV=development

# Supabase Auth (ES256 非对称签名, 无需 shared secret)
# 从 Supabase Dashboard 或 Management API 拿:
#   GET https://api.supabase.com/v1/projects/<ref>/api-keys
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
# Publishable key 给前端 (sb_publishable_*); Secret key 给服务端 admin 操作 (sb_secret_*)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# (可选) Cloudflare Turnstile - 匿名创建保护
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# (可选) 站点域名, 用于生成完整短链 URL
PUBLIC_BASE_URL=http://localhost:3000
