# 数据库 - Supabase Postgres connection string
# 形如: postgres://postgres.xxx:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# 服务端口 (Railway 自动注入 PORT, 本地开发默认 3000)
PORT=3000

# 运行环境
NODE_ENV=development

# Supabase Auth (ES256 非对称签名, 无需 shared secret)
# 从 Supabase Dashboard 或 Management API 拿:
#   GET https://api.supabase.com/v1/projects/<ref>/api-keys
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
# Publishable key 给前端 (sb_publishable_*); Secret key 给服务端 admin 操作 (sb_secret_*)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# (暂缓, P2 再评估) Cloudflare Turnstile - 匿名创建保护
# 当前用 src/middleware/ratelimit.ts 内存 IP+UA token bucket 兜底
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# 站点域名 - 用于生成完整短链 URL 和 Supabase 魔法链接回跳
PUBLIC_BASE_URL=http://localhost:3000

# 品牌主题 - 留空为默认 Open GoLinks; 设为 zgzg 时使用 zgzg.li 文案、红色主色和 ZGZG logo
OPEN_GOLINK_THEME=

# audit_logs.actor_ip_hash 加盐 (SHA-256(IP + salt))
# 本地用 `openssl rand -hex 32` 生成一次写入 .env, 不入 git
IP_HASH_SALT=

# === Google Analytics (沿用 master, 历史数据连续) ===
# Measurement Protocol (后端上报 redirect 事件)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
# GA4 Data API (dashboard 取数)
GA4_PROPERTY_ID=
# base64 编码的 GCP service account JSON (有 GA4 Data API 读权限)
# 在 src/lib/gcp.ts 启动时解码到 /tmp/gcp-key.json 供 SDK 使用
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# === 前端 (Vite, VITE_ 前缀才会进 client bundle) ===
# 值同对应服务端变量, 但 Vite 安全机制要求显式 VITE_ 前缀
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_BASE_URL=http://localhost:3000
