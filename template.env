# ============ DATABASE ============
DATABASE_URL=postgresql://user:password@localhost:5432/open_golinks

# ============ SUPABASE ============
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# ============ AUTH ============
AUTH_JWT_SECRET=[your-jwt-secret]

# ============ TURNSTILE ============
NEXT_PUBLIC_TURNSTILE_SITE_KEY=[cloudflare-turnstile-site-key]
TURNSTILE_SECRET_KEY=[cloudflare-turnstile-secret-key]

# ============ ANALYTICS ============
NEXT_PUBLIC_GA4_MEASUREMENT_ID=[google-analytics-4-id]
NEXT_PUBLIC_GA4_API_SECRET=[ga4-api-secret]

# ============ SECURITY ============
IP_HASH_SALT=[random-hex-string-32-chars]

# ============ API ============
API_RATE_LIMIT_WINDOW_MS=3600000
API_RATE_LIMIT_MAX_REQUESTS_ANON=5
API_RATE_LIMIT_MAX_REQUESTS_AUTH=50

# ============ ENVIRONMENT ============
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_VERSION=v1
