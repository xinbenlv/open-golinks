{
  "name": "open-golinks-v2-hono",
  "version": "2.0.0-hono.1",
  "description": "短链与 analytics 服务 - Bun + Hono + Drizzle + Vite/React 实现",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "dev:web": "vite",
    "build:web": "vite build && bun scripts/prerender.ts",
    "build": "bun run build:web",
    "start": "NODE_ENV=production bun src/server.ts",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/run-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "migrate:legacy": "bun scripts/migrate-from-legacy.ts",
    "migrate:legacy:dry": "bun scripts/migrate-from-legacy.ts --dry-run",
    "migrate:legacy:replace": "bun scripts/migrate-from-legacy.ts --replace-all"
  },
  "dependencies": {
    "@google-analytics/data": "^6.0.0",
    "@napi-rs/canvas": "^1.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "mongodb": "^7.2.0",
    "nanoid": "^5.0.0",
    "postgres": "^3.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.28.0",
    "puppeteer-core": "^24.43.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
