{
  "name": "open-golinks-v2-hono",
  "version": "2.0.0-hono.0",
  "description": "短链与 analytics 服务 - Bun + Hono + Drizzle + Vite/React 实现",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "dev:web": "vite",
    "build:web": "vite build && bun scripts/prerender.ts",
    "build": "bun run build:web",
    "start": "NODE_ENV=production bun src/server.ts",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/run-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "migrate:legacy": "bun scripts/migrate-from-legacy.ts",
    "migrate:legacy:dry": "bun scripts/migrate-from-legacy.ts --dry-run"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "nanoid": "^5.0.0",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
